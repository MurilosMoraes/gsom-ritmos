{
  "name": "rhythm-sequencer",
  "version": "1.3.8",
  "description": "Sequenciador de ritmos MIDI para web",
  "main": "app.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "build:mobile": "tsc && vite build && npm run copy:www",
    "copy:www": "rm -rf www && mkdir -p www && cp -r dist/* www/",
    "postinstall": "patch-package || true"
  },
  "keywords": [
    "midi",
    "sequencer",
    "rhythm",
    "music"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "patch-package": "^8.0.1",
    "typescript": "^5.3.3",
    "vite": "^7.2.7"
  },
  "dependencies": {
    "@capacitor-community/keep-awake": "^8.0.1",
    "@capacitor-firebase/messaging": "^8.2.0",
    "@capacitor/android": "^8.0.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/push-notifications": "^8.0.4",
    "@capacitor/status-bar": "^8.0.1",
    "@capawesome/capacitor-android-edge-to-edge-support": "^8.0.8",
    "@capgo/capacitor-native-biometric": "^8.6.0",
    "@capgo/native-purchases": "^8.3.6",
    "@supabase/supabase-js": "^2.99.3",
    "ajv": "^8.20.0",
    "firebase": "^12.13.0",
    "globe.gl": "^2.45.3",
    "tar": "^7.5.15",
    "vite-plugin-pwa": "^1.2.0",
    "zod": "^4.3.6"
  }
}
